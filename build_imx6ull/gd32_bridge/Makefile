	cd /home/jayce/linux/IMX6ULL/C_APP/pwm/KF-GINS-main/build_imx6ull && $(CMAKE_COMMAND) -P /home/jayce/linux/IMX6ULL/C_APP/pwm/KF-GINS-main/build_imx6ull/CMakeFiles/VerifyGlobs.cmake
	cd /home/jayce/linux/IMX6ULL/C_APP/pwm/KF-GINS-main/build_imx6ull && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
.PHONY : cmake_check_build_system

